# ============================================================
# OutfAI — environment variable template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Convex
# Run `npx convex dev` once to create your deployment.
# The CLI writes CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL
# into .env.local automatically.
# ------------------------------------------------------------
CONVEX_DEPLOYMENT=dev:your-deployment-slug
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-slug.convex.cloud

# Same as NEXT_PUBLIC_CONVEX_URL but ends in .site (used for auth HTTP routes)
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-slug.convex.site

# Your local dev URL — used by BetterAuth as the base URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------
# Auth secrets — set these via the Convex CLI, NOT in .env.local:
#   npx convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)
#   npx convex env set SITE_URL http://localhost:3000
# (These live in your Convex deployment environment, not locally.)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Google Cloud Vision (garment image recognition / auto-fill attributes)
# Set this in .env.local only, e.g.:
#   GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-vision-key.json
# ------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------
# Weather API
# Open-Meteo is free and requires no key.
# Uncomment if you switch to OpenWeatherMap.
# ------------------------------------------------------------
# OPENWEATHERMAP_API_KEY=
