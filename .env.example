# ============================================================
# OutfAI — environment variable template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Convex
# Run `npx convex dev` once to create your deployment.
# The CLI writes CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL
# into .env.local automatically.
# ------------------------------------------------------------
CONVEX_DEPLOYMENT=dev:your-deployment-slug
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-slug.convex.cloud

# Same as NEXT_PUBLIC_CONVEX_URL but ends in .site (used for auth HTTP routes)
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-slug.convex.site

# Your local dev URL — used by BetterAuth as the base URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: auto-seed mock closet on first home visit (dev demos only).
# Convex mutation also requires ALLOW_DEV_CLOSET_SEED=true on the deployment.
# NEXT_PUBLIC_DEV_SEED_CLOSET=true

# ------------------------------------------------------------
# Auth secrets — set these via the Convex CLI, NOT in .env.local:
#   npx convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)
#   npx convex env set SITE_URL http://localhost:3000
# Optional dev-only (short passwords + mock closet seed):
#   npx convex env set ALLOW_WEAK_DEV_PASSWORDS true
#   npx convex env set ALLOW_DEV_CLOSET_SEED true
# (These live in your Convex deployment environment, not locally.)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Email verification (Resend) — set in Convex dashboard / env:
#   npx convex env set RESEND_API_KEY re_xxxx
# Optional: custom "from" address (default: onboarding@resend.dev):
#   npx convex env set EMAIL_FROM "OutfAI <noreply@yourdomain.com>"
# ------------------------------------------------------------

# ------------------------------------------------------------
# Google Cloud Vision (garment image recognition / auto-fill attributes)
# Set this in .env.local only, e.g.:
#   GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-vision-key.json
# ------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------
# Commerce / product recommendations (live retailers only)
# Set at least one provider for "Suggested for your wardrobe" to return real products.
# See docs/commerce/PROVIDERS.md for how to obtain keys.
# ------------------------------------------------------------

# Amazon (Product Advertising API 5.0 — requires Associates + PA-API approval)
# AMAZON_ACCESS_KEY=
# AMAZON_SECRET_KEY=
# AMAZON_PARTNER_TAG=

# Walmart (Affiliate API — register at walmart.io)
# WALMART_PUBLISHER_ID=
# WALMART_CONSUMER_ID=
# WALMART_PRIVATE_KEY=

# Macy's (Catalog API — approved partners only)
# MACYS_API_KEY=

# Best Buy (Developer API — free key at developer.bestbuy.com)
# BEST_BUY_API_KEY=

# Generic JSON product feed (URL returning array or { "products": [] })
# COMMERCE_FEED_URL=

# ------------------------------------------------------------
# Weather API
# Open-Meteo is free and requires no key.
# Uncomment if you switch to OpenWeatherMap.
# ------------------------------------------------------------
# OPENWEATHERMAP_API_KEY=
