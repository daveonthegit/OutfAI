{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@server/*": ["../../server/*"],
      "@shared/*": ["../../shared/*"],
      "@convex/*": ["../../convex/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../convex/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
